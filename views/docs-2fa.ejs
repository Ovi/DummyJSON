<!DOCTYPE html>
<html lang="en">
<!-- header -->
<%- include('./partials/docs-head') %>

<body>
  <!-- header -->
  <%- include('./partials/header') %>

  <!-- side-nav -->
  <%- include('./partials/docs-side-nav') %>

  <section>
    <div class="content">
      <h1 class="docs-title">
        <img src="/public/img/icons/globe.svg" class="icon" alt="svg icon" /> 2FA TOTP - Docs
      </h1>
      <p class="display-para">
        The <strong>2fa</strong> endpoint generates real TOTP verification codes from an authenticator secret key.
        It is compatible with Google Authenticator, Authy, and other standard TOTP apps.
      </p>

      <div class="resource" id="2fa-get">
        <a href="#2fa-get" class="res-title">Generate TOTP (GET)</a>
        <p class="res-tip">
          Pass your base32 secret key as a query parameter:
          <br />
          <a href="https://dummyjson.com/2fa?key=JBSWY3DPEHPK3PXP">dummyjson.com/2fa?key=YOUR_SECRET</a>
        </p>
        <pre><code class="language-js">
          fetch('https://dummyjson.com/2fa?key=JBSWY3DPEHPK3PXP')
          .then(res => res.json())
          .then(console.log);
        </code></pre>

        <button class="show-output btn">Show Output</button>

        <pre class="output"><code class="language-json">
          {
            "totp": "123456",
            "expiresIn": 17,
            "period": 30
          }
        </code></pre>
      </div>

      <div class="resource" id="2fa-post">
        <a href="#2fa-post" class="res-title">Generate TOTP (POST)</a>
        <p class="res-tip">
          Prefer POST when sending secrets — it keeps the key out of URLs and server logs.
        </p>
        <pre><code class="language-js">
          fetch('https://dummyjson.com/2fa', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ key: 'JBSWY3DPEHPK3PXP' })
          })
          .then(res => res.json())
          .then(console.log);
        </code></pre>

        <button class="show-output btn">Show Output</button>

        <pre class="output"><code class="language-json">
          {
            "totp": "123456",
            "expiresIn": 17,
            "period": 30
          }
        </code></pre>
      </div>

      <div class="resource" id="2fa-formats">
        <a href="#2fa-formats" class="res-title">Supported Secret Formats</a>
        <p class="res-desc">The endpoint accepts the following secret formats:</p>
        <ul class="res-list">
          <li><strong>Base32 secret</strong> — e.g. <code>JBSWY3DPEHPK3PXP</code> (spaces and dashes are stripped automatically)</li>
          <li><strong>otpauth URI</strong> — e.g. <code>otpauth://totp/Label?secret=JBSWY3DPEHPK3PXP&amp;issuer=Example</code></li>
        </ul>
        <p class="res-tip">
          Try the interactive tool at <a href="https://dummyjson.com/2fa">dummyjson.com/2fa</a>.
          The endpoint is also available at <code>/totp</code>.
        </p>
      </div>
    </div>
  </section>

  <!-- footer -->
  <%- include('./partials/docs-footer') %>

  <script>
    selectNavItem(window.location.hash || '#2fa-get');
  </script>
</body>

</html>
